{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Portal",
  "version": "0.1.0",
  "identifier": "com.agentportal.app",
  "build": {
    "beforeDevCommand": "pnpm --dir ui start",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "pnpm --dir ui build",
    "frontendDist": "../ui/dist/agent-portal/browser"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Portal",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
